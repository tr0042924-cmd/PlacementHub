<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Company Dashboard - Campus Placement Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            line-height: 1.6;
        }

        .dashboard-container {
            min-height: 100vh;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        }

        .dashboard-header {
            background: linear-gradient(135deg, #10B981 0%, #059669 100%);
            padding: 20px 0;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            background: rgba(255, 255, 255, 0.2);
            border: 3px solid rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(10px);
        }

        .user-info h1 {
            color: white;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 4px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }

        .user-info p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 16px;
            font-weight: 400;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .notification-bell {
            font-size: 24px;
            cursor: pointer;
            padding: 12px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.15);
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .notification-bell:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: scale(1.05);
        }

        .logout-btn {
            padding: 12px 24px;
            background: rgba(255, 255, 255, 0.2);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: 2px solid rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(10px);
        }

        .logout-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
        }

        .dashboard-main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .company-overview {
            margin-bottom: 60px;
        }

        .company-profile-card {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            gap: 30px;
            backdrop-filter: blur(20px);
            position: relative;
            overflow: hidden;
        }

        .company-profile-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #10B981, #059669);
        }

        .company-logo-large {
            width: 100px;
            height: 100px;
            border-radius: 20px;
            background: linear-gradient(135deg, #10B981, #059669);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 50px;
            color: white;
            box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
        }

        .company-details h2 {
            font-size: 32px;
            font-weight: 700;
            color: #1F2937;
            margin-bottom: 20px;
        }

        .company-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }

        .info-item {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .info-label {
            font-size: 14px;
            font-weight: 500;
            color: #6B7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .info-value {
            font-size: 20px;
            font-weight: 600;
            color: #1F2937;
        }

        .package-amount {
            color: #10B981;
            font-size: 24px;
            font-weight: 700;
        }

        .quick-actions {
            margin-bottom: 40px;
        }

        .section-header {
            margin-bottom: 30px;
        }

        .section-header h2 {
            font-size: 32px;
            font-weight: 700;
            color: #1F2937;
            margin-bottom: 8px;
        }

        .section-header p {
            color: #6B7280;
            font-size: 18px;
            font-weight: 400;
        }

        .actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 24px;
        }

        .action-card {
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            gap: 20px;
            text-decoration: none;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .action-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
        }

        .action-card.primary::before {
            background: linear-gradient(90deg, #3B82F6, #1D4ED8);
        }

        .action-card.secondary::before {
            background: linear-gradient(90deg, #10B981, #059669);
        }

        .action-card.tertiary::before {
            background: linear-gradient(90deg, #F59E0B, #D97706);
        }

        .action-card:hover::before {
            transform: scaleX(1);
        }

        .action-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        }

        .action-icon {
            width: 70px;
            height: 70px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .primary .action-icon {
            background: linear-gradient(135deg, #DBEAFE, #BFDBFE);
            color: #3B82F6;
        }

        .secondary .action-icon {
            background: linear-gradient(135deg, #D1FAE5, #A7F3D0);
            color: #10B981;
        }

        .tertiary .action-icon {
            background: linear-gradient(135deg, #FEF3C7, #FDE68A);
            color: #F59E0B;
        }

        .action-card:hover .action-icon {
            transform: scale(1.1);
        }

        .action-content {
            flex: 1;
        }

        .action-content h3 {
            font-size: 22px;
            font-weight: 700;
            color: #1F2937;
            margin-bottom: 8px;
        }

        .action-content p {
            color: #6B7280;
            font-size: 16px;
            line-height: 1.5;
        }

        .action-arrow {
            font-size: 28px;
            color: #9CA3AF;
            transition: all 0.3s ease;
            font-weight: bold;
        }

        .action-card:hover .action-arrow {
            color: #3B82F6;
            transform: translateX(8px);
        }

        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                gap: 16px;
                text-align: center;
            }

            .dashboard-main {
                padding: 20px 16px;
            }

            .company-profile-card {
                flex-direction: column;
                text-align: center;
                padding: 30px 20px;
            }

            .section-header h2 {
                font-size: 24px;
            }

            .actions-grid {
                grid-template-columns: 1fr;
            }

            .action-card {
                padding: 24px;
                gap: 16px;
            }

            .action-icon {
                width: 60px;
                height: 60px;
                font-size: 28px;
            }

            .action-content h3 {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <header class="dashboard-header">
            <div class="header-content">
                <div class="header-left">
                    <div class="user-avatar">🏢</div>
                    <div class="user-info">
                        <h1>Welcome, <%= company.name %></h1>
                        <p>Company Dashboard</p>
                    </div>
                </div>
                <div class="header-right">
                    <div class="notification-bell">🔔</div>
                    <a href="/logout" class="logout-btn">Logout</a>
                </div>
            </div>
        </header>

        <main class="dashboard-main">
            <div class="company-overview">
                <div class="company-profile-card">
                    <div class="company-logo-large">🏢</div>
                    <div class="company-details">
                        <h2><%= company.name %></h2>
                        <div class="company-info-grid">
                            <div class="info-item">
                                <span class="info-label">Role Offered</span>
                                <span class="info-value"><%= company.role_offered %></span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Package</span>
                                <span class="info-value package-amount">₹<%= company.package.toLocaleString() %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="quick-actions">
                <div class="section-header">
                    <h2>Quick Actions</h2>
                    <p>Manage your recruitment process</p>
                </div>
                
                <div class="actions-grid">
                    <a href="/company_applications" class="action-card primary">
                        <div class="action-icon">📋</div>
                        <div class="action-content">
                            <h3>View Applications</h3>
                            <p>Review and manage student applications</p>
                        </div>
                        <div class="action-arrow">→</div>
                    </a>
                    
                    <div class="action-card secondary">
                        <div class="action-icon">📊</div>
                        <div class="action-content">
                            <h3>Analytics</h3>
                            <p>View application statistics</p>
                        </div>
                        <div class="action-arrow">→</div>
                    </div>
                    
                    <div class="action-card tertiary">
                        <div class="action-icon">⚙️</div>
                        <div class="action-content">
                            <h3>Settings</h3>
                            <p>Update company preferences</p>
                        </div>
                        <div class="action-arrow">→</div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>