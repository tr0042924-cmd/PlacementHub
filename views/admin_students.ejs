<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Students</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .header {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 2.5rem;
            font-weight: 300;
            margin-bottom: 10px;
        }
        
        .content {
            padding: 40px;
        }
        
        .students-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }
        
        .student-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            border-top: 4px solid transparent;
            position: relative;
            overflow: hidden;
        }
        
        .student-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
        }
        
        .student-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        
        .student-name {
            font-size: 1.4rem;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        
        .student-email {
            font-size: 1rem;
            color: #7f8c8d;
            margin-bottom: 8px;
        }
        
        .student-department {
            font-size: 1.1rem;
            color: #667eea;
            font-weight: 600;
            margin-bottom: 12px;
        }
        
        .cgpa-badge {
            display: inline-block;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 0.95rem;
            font-weight: 700;
            color: white;
        }
        
        .cgpa-excellent {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        }
        
        .cgpa-good {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        
        .cgpa-average {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }
        
        .back-link {
            display: inline-block;
            margin-top: 30px;
            padding: 15px 30px;
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(79, 172, 254, 0.3);
        }
        
        .back-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(79, 172, 254, 0.4);
        }
        
        .stats-bar {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 30px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            text-align: center;
        }
        
        .stat-item {
            padding: 10px;
        }
        
        .stat-number {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 5px;
            color: #4facfe;
        }
        
        .stat-label {
            color: #7f8c8d;
            font-size: 1rem;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #7f8c8d;
        }
        
        .empty-state h3 {
            font-size: 1.5rem;
            margin-bottom: 10px;
        }
        
        .search-bar {
            margin-bottom: 30px;
            position: relative;
        }
        
        .search-input {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e9ecef;
            border-radius: 25px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        
        .search-input:focus {
            outline: none;
            border-color: #4facfe;
            box-shadow: 0 0 0 3px rgba(79, 172, 254, 0.1);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>All Registered Students</h1>
        </div>
        <div class="content">
            <% if (students && students.length > 0) { %>
                <div class="stats-bar">
                    <div class="stat-item">
                        <div class="stat-number"><%= students.length %></div>
                        <div class="stat-label">Total Students</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number"><%= students.filter(s => s.cgpa >= 8.0).length %></div>
                        <div class="stat-label">High Performers (8.0+)</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number"><%= [...new Set(students.map(s => s.department))].length %></div>
                        <div class="stat-label">Departments</div>
                    </div>
                </div>
                
                <div class="search-bar">
                    <input type="text" class="search-input" placeholder="Search students by name, email, or department..." id="searchInput">
                </div>
                
                <div class="students-grid" id="studentsGrid">
                    <% students.forEach(s => { %>
                        <div class="student-card" data-name="<%= s.name.toLowerCase() %>" data-email="<%= s.email.toLowerCase() %>" data-department="<%= s.department.toLowerCase() %>">
                            <div class="student-name"><%= s.name %></div>
                            <div class="student-email"><%= s.email %></div>
                            <div class="student-department"><%= s.department %></div>
                            <span class="cgpa-badge <%= s.cgpa >= 8.5 ? 'cgpa-excellent' : s.cgpa >= 7.0 ? 'cgpa-good' : 'cgpa-average' %>">
                                CGPA: <%= s.cgpa %>
                            </span>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <h3>No students registered yet</h3>
                    <p>Student records will appear here once they register.</p>
                </div>
            <% } %>
            <a href="/admin" class="back-link">← Back to Admin</a>
        </div>
    </div>
    
    <script>
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const studentCards = document.querySelectorAll('.student-card');
            
            studentCards.forEach(card => {
                const name = card.dataset.name;
                const email = card.dataset.email;
                const department = card.dataset.department;
                
                if (name.includes(searchTerm) || email.includes(searchTerm) || department.includes(searchTerm)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>