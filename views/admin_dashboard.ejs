<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Campus Placement Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            line-height: 1.6;
        }

        .dashboard-container {
            min-height: 100vh;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        }

        .dashboard-header {
            background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
            padding: 20px 0;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            background: rgba(255, 255, 255, 0.2);
            border: 3px solid rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(10px);
        }

        .user-info h1 {
            color: white;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 4px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }

        .user-info p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 16px;
            font-weight: 400;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .notification-bell {
            font-size: 24px;
            cursor: pointer;
            padding: 12px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.15);
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .notification-bell:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: scale(1.05);
        }

        .logout-btn {
            padding: 12px 24px;
            background: rgba(255, 255, 255, 0.2);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: 2px solid rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(10px);
        }

        .logout-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
        }

        .dashboard-main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .admin-overview {
            margin-bottom: 60px;
        }

        .section-header {
            margin-bottom: 30px;
        }

        .section-header h2 {
            font-size: 32px;
            font-weight: 700;
            color: #1F2937;
            margin-bottom: 8px;
        }

        .section-header p {
            color: #6B7280;
            font-size: 18px;
            font-weight: 400;
        }

        .admin-actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px;
            margin-bottom: 60px;
        }

        .admin-action-card {
            background: white;
            padding: 32px;
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            gap: 20px;
            text-decoration: none;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .admin-action-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
        }

        .admin-action-card.primary::before {
            background: linear-gradient(90deg, #3B82F6, #1D4ED8);
        }

        .admin-action-card.secondary::before {
            background: linear-gradient(90deg, #10B981, #059669);
        }

        .admin-action-card.tertiary::before {
            background: linear-gradient(90deg, #F59E0B, #D97706);
        }

        .admin-action-card.accent::before {
            background: linear-gradient(90deg, #8B5CF6, #7C3AED);
        }

        .admin-action-card:hover::before {
            transform: scaleX(1);
        }

        .admin-action-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        }

        .action-icon {
            width: 70px;
            height: 70px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .primary .action-icon {
            background: linear-gradient(135deg, #DBEAFE, #BFDBFE);
            color: #3B82F6;
        }

        .secondary .action-icon {
            background: linear-gradient(135deg, #D1FAE5, #A7F3D0);
            color: #10B981;
        }

        .tertiary .action-icon {
            background: linear-gradient(135deg, #FEF3C7, #FDE68A);
            color: #F59E0B;
        }

        .accent .action-icon {
            background: linear-gradient(135deg, #F3E8FF, #E9D5FF);
            color: #8B5CF6;
        }

        .admin-action-card:hover .action-icon {
            transform: scale(1.1);
        }

        .action-content {
            flex: 1;
        }

        .action-content h3 {
            font-size: 22px;
            font-weight: 700;
            color: #1F2937;
            margin-bottom: 8px;
        }

        .action-content p {
            color: #6B7280;
            font-size: 16px;
            line-height: 1.5;
        }

        .action-arrow {
            font-size: 28px;
            color: #9CA3AF;
            transition: all 0.3s ease;
            font-weight: bold;
        }

        .admin-action-card:hover .action-arrow {
            color: #8B5CF6;
            transform: translateX(8px);
        }

        .export-section {
            margin-bottom: 60px;
        }

        .export-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .export-card {
            background: white;
            padding: 28px;
            border-radius: 16px;
            box-shadow: 0 6px 25px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.2);
            text-decoration: none;
            transition: all 0.3s ease;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .export-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #3B82F6, #8B5CF6);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
        }

        .export-card:hover::before {
            transform: scaleX(1);
        }

        .export-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.12);
        }

        .export-icon {
            font-size: 40px;
            margin-bottom: 16px;
            opacity: 0.8;
        }

        .export-content h3 {
            font-size: 18px;
            font-weight: 700;
            color: #1F2937;
            margin-bottom: 8px;
        }

        .export-content p {
            color: #6B7280;
            font-size: 14px;
            line-height: 1.4;
        }

        .quick-nav {
            text-align: center;
            margin-top: 40px;
        }

        .home-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 28px;
            background: linear-gradient(135deg, #3B82F6, #1D4ED8);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 16px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
        }

        .home-link:hover {
            background: linear-gradient(135deg, #1D4ED8, #1E40AF);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59, 130, 246, 0.4);
        }

        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                gap: 16px;
                text-align: center;
            }

            .dashboard-main {
                padding: 20px 16px;
            }

            .section-header h2 {
                font-size: 24px;
            }

            .admin-actions-grid {
                grid-template-columns: 1fr;
            }

            .admin-action-card {
                padding: 24px;
                gap: 16px;
            }

            .action-icon {
                width: 60px;
                height: 60px;
                font-size: 28px;
            }

            .action-content h3 {
                font-size: 20px;
            }

            .export-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <header class="dashboard-header">
            <div class="header-content">
                <div class="header-left">
                    <div class="user-avatar">👨‍💼</div>
                    <div class="user-info">
                        <h1>Admin Dashboard</h1>
                        <p>Placement Administration Panel</p>
                    </div>
                </div>
                <div class="header-right">
                    <div class="notification-bell">🔔</div>
                    <a href="/admin_logout" class="logout-btn">Logout</a>
                </div>
            </div>
        </header>

        <main class="dashboard-main">
            <div class="admin-overview">
                <div class="section-header">
                    <h2>Administrative Controls</h2>
                    <p>Manage the entire placement process</p>
                </div>
                
                <div class="admin-actions-grid">
                    <a href="/admin/students" class="admin-action-card primary">
                        <div class="action-icon">👥</div>
                        <div class="action-content">
                            <h3>View All Students</h3>
                            <p>Manage student records and profiles</p>
                        </div>
                        <div class="action-arrow">→</div>
                    </a>
                    
                    <a href="/admin/applications" class="admin-action-card secondary">
                        <div class="action-icon">📋</div>
                        <div class="action-content">
                            <h3>View All Applications</h3>
                            <p>Monitor all job applications</p>
                        </div>
                        <div class="action-arrow">→</div>
                    </a>
                    
                    <a href="/admin/placements" class="admin-action-card tertiary">
                        <div class="action-icon">🎯</div>
                        <div class="action-content">
                            <h3>View All Placements</h3>
                            <p>Track successful placements</p>
                        </div>
                        <div class="action-arrow">→</div>
                    </a>
                    
                    <a href="/admin/place" class="admin-action-card accent">
                        <div class="action-icon">✅</div>
                        <div class="action-content">
                            <h3>Mark Placement Offers</h3>
                            <p>Record new placement offers</p>
                        </div>
                        <div class="action-arrow">→</div>
                    </a>
                </div>
            </div>

            <div class="export-section">
                <div class="section-header">
                    <h2>Data Export</h2>
                    <p>Export data for analysis and reporting</p>
                </div>
                
                <div class="export-grid">
                    <a href="/admin/export/students" class="export-card">
                        <div class="export-icon">📊</div>
                        <div class="export-content">
                            <h3>Export Students CSV</h3>
                            <p>Download student data</p>
                        </div>
                    </a>
                    
                    <a href="/admin/export/applications" class="export-card">
                        <div class="export-icon">📈</div>
                        <div class="export-content">
                            <h3>Export Applications CSV</h3>
                            <p>Download application data</p>
                        </div>
                    </a>
                    
                    <a href="/admin/export/placements" class="export-card">
                        <div class="export-icon">🎯</div>
                        <div class="export-content">
                            <h3>Export Placements CSV</h3>
                            <p>Download placement data</p>
                        </div>
                    </a>
                </div>
            </div>

            <div class="quick-nav">
                <a href="/" class="home-link">🏠 Home</a>
            </div>
        </main>
    </div>
</body>
</html>